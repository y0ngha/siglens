{
    "name": "siglens",
    "version": "0.8.0",
    "private": true,
    "author": "신용하 <dev.y0ngha@gmail.com>",
    "scripts": {
        "dev": "next dev --turbopack -p 4200",
        "build": "rm -rf .next && next build",
        "start": "next start",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:style": "stylelint --allow-empty-input '**/*.{css,scss}'",
        "lint:style-fix": "stylelint --fix '**/*.{css,scss}'",
        "test": "jest",
        "test-watch": "jest --watch",
        "test-coverage": "jest --coverage",
        "test-coverage-watch": "jest --coverage --watch",
        "test-coverage-report": "jest --coverage --coverageReporters=text-summary",
        "format": "prettier --write .",
        "prepare": "husky",
        "release": "dotenv -e .env.local -- release-it",
        "release:patch": "dotenv -e .env.local -- release-it patch",
        "release:minor": "dotenv -e .env.local -- release-it minor",
        "release:major": "dotenv -e .env.local -- release-it major",
        "worker:run": "cd worker && yarn dev"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.80.0",
        "@google/generative-ai": "^0.24.1",
        "@tanstack/react-query": "^5.95.2",
        "@types/jest": "^30.0.0",
        "@upstash/redis": "^1.37.0",
        "@vercel/functions": "^3.4.3",
        "clsx": "^2.1.1",
        "lightweight-charts": "^5.1.0",
        "next": "16.2.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-error-boundary": "^6.1.1",
        "tailwind-merge": "^3.5.0",
        "vaul": "^1.1.2"
    },
    "devDependencies": {
        "@release-it/conventional-changelog": "^10.0.6",
        "@tailwindcss/postcss": "^4",
        "@tanstack/react-query-devtools": "5",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.0",
        "eslint-plugin-react-compiler": "^19.1.0-rc.2",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "postcss-html": "^1.8.0",
        "prettier": "^3.7.4",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "release-it": "^19.2.4",
        "stylelint": "^16.26.1",
        "stylelint-config-recess-order": "^7.4.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^7.0.0",
        "tailwindcss": "^4",
        "ts-jest": "^29.4.6",
        "typescript": "^5"
    },
    "packageManager": "yarn@4.12.0"
}
