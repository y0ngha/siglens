        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.0",
        "eslint-plugin-react-compiler": "^19.1.0-rc.2",
        "jest": "^30.2.0",
        "postcss-html": "^1.8.0",
        "prettier": "^3.7.4",
