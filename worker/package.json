{
    "name": "siglens-worker",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "yarn@4.12.0",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx --env-file=.env src/index.ts",
        "test": "jest --config jest.config.cjs",
        "deploy": "gcloud run deploy siglens-worker --source . --region asia-northeast3 --timeout 3600 --memory 512Mi --cpu 1 --min-instances 0 --max-instances 3 --allow-unauthenticated --env-vars-file .env.yaml"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "0.81.0",
        "@google/genai": "^1.49.0",
        "@upstash/redis": "^1.34.3",
        "@y0ngha/siglens-core": "^0.1.7",
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.2",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.15.3",
        "jest": "^29.7.0",
        "ts-jest": "^29.3.2",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    }
}
