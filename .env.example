# ── Market Data ────────────────────────────────────────────────────────────
# https://site.financialmodelingprep.com/developer
FMP_API_KEY=

# ── AI — Chatbot ──────────────────────────────────────────────────────────
# Server api key per provider — covers free-tier models (server pays).
# https://aistudio.google.com/apikey
GEMINI_CHAT_API_KEY=
# https://console.anthropic.com/settings/keys
ANTHROPIC_CHAT_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_CHAT_API_KEY=

# ── Ticker Translation ─────────────────────────────────────────────────────
# Gemini key for company-name/description translation
# (can be same value as GEMINI_CHAT_API_KEY)
TRANSLATE_API_KEY=
TRANSLATE_MODEL=

# ── Cache (Upstash Redis) ──────────────────────────────────────────────────
# https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_READONLY_TOKEN=

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# https://neon.tech
DATABASE_URL=

# ── Authentication ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# Reserved for a future KakaoTalk desktop share button (not yet wired).
# Mobile KakaoTalk sharing already works via the OS share sheet.
NEXT_PUBLIC_KAKAO_JS_KEY=
OAUTH_REDIRECT_BASE_URL=
# 32-byte hex strings — used to encrypt OAuth tokens and user API keys at rest
# Generate with: openssl rand -hex 32
OAUTH_TOKEN_ENCRYPTION_KEY=
LLM_API_KEY_ENCRYPTION_KEY=
# HMAC secret used to sign OAuth state cookies. Must be at least 32 bytes.
# Generate with: openssl rand -hex 32  (or any other source of 32+ bytes)
OAUTH_STATE_HMAC_SECRET=

# Bearer token required by cleanupExpiredSessionsAction. Set to the same value
# used by the external cron caller (e.g. EventBridge). Action throws unauthorized when
# missing, so production deployments must define this even if cron is not yet
# wired.
CRON_SECRET=

# ── Email (Resend) ─────────────────────────────────────────────────────────
# https://resend.com
RESEND_API_KEY=
EMAIL_FROM=

# ── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=

# ── AdSense ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=
NEXT_PUBLIC_ADSENSE_SLOT_PROGRESS=
NEXT_PUBLIC_ADSENSE_SLOT_PANEL_BOTTOM=
NEXT_PUBLIC_ADSENSE_ENABLED=false

# ── Package Registry ───────────────────────────────────────────────────────
# GitHub token with read:packages scope — for installing @y0ngha/siglens-core
# https://github.com/settings/tokens
SIGLENS_GITHUB_TOKEN=

# ── Worker ───────────────────────────────────────────────────────
WORKER_URL=
WORKER_SECRET=

# ── ISR Cache (S3) ─────────────────────────────────────────────────────────
# S3 버킷 이름. 값이 있으면 production에서 ISR/fetch 캐시를 이 버킷으로 외부화하는
# cacheHandler를 활성화한다(디스크풀 방지). prod는 SSM(/siglens/ISR_CACHE_BUCKET)으로
# 주입되고 빌드 타임엔 deploy.yml의 build-arg로도 전달된다. dev는 비워두면 기본
# 파일시스템 캐시로 폴백한다.
ISR_CACHE_BUCKET=

# ── Ops Alerts (CloudWatch → SNS) ──────────────────────────────────────────
# infra/aws/07-alarms.sh가 SNS 토픽(siglens-alerts)을 idempotent 생성하고, 아래
# 주소가 설정돼 있으면 이메일을 구독한다(구독 후 confirm 메일 클릭 필요). 비워두면
# 토픽만 만들고 구독은 건너뛴다 — 알람 액션 자체는 항상 토픽에 연결된다.
ALARM_EMAIL=

# ── Debug ──────────────────────────────────────────────────────────────────
# Server-only verbose debug log toggle. Set to any truthy value (e.g. "1")
# to enable logs that may include user-facing content (e.g. translated news
# titles in submitNewsAnalysisAction). Leave empty in production.
# Intentionally NOT prefixed with NEXT_PUBLIC_ — that prefix inlines the
# value into the client bundle and would expose it to end users.
DEBUG_VERBOSE_LOGS=