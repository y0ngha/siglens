{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "EcrAuth",
            "Effect": "Allow",
            "Action": ["ecr:GetAuthorizationToken"],
            "Resource": "*"
        },
        {
            "Sid": "EcrPush",
            "Effect": "Allow",
            "Action": [
                "ecr:BatchCheckLayerAvailability",
                "ecr:BatchGetImage",
                "ecr:GetDownloadUrlForLayer",
                "ecr:InitiateLayerUpload",
                "ecr:UploadLayerPart",
                "ecr:CompleteLayerUpload",
                "ecr:PutImage"
            ],
            "Resource": "arn:aws:ecr:ap-northeast-2:ACCOUNT_ID:repository/siglens"
        },
        {
            "Sid": "DeployDescribe",
            "Effect": "Allow",
            "Action": [
                "ec2:DescribeSecurityGroups",
                "ec2:DescribeLaunchTemplates",
                "ec2:DescribeLaunchTemplateVersions",
                "elasticloadbalancing:DescribeLoadBalancers",
                "elasticloadbalancing:DescribeListeners",
                "elasticloadbalancing:DescribeRules",
                "autoscaling:DescribeAutoScalingGroups",
                "autoscaling:DescribeInstanceRefreshes"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AlbRedirectCreateRule",
            "Effect": "Allow",
            "Action": ["elasticloadbalancing:CreateRule"],
            "Resource": "arn:aws:elasticloadbalancing:ap-northeast-2:ACCOUNT_ID:listener/app/siglens-alb/*/*"
        },
        {
            "Sid": "AlbRedirectModifyRule",
            "Effect": "Allow",
            "Action": ["elasticloadbalancing:ModifyRule"],
            "Resource": "arn:aws:elasticloadbalancing:ap-northeast-2:ACCOUNT_ID:listener-rule/app/siglens-alb/*/*/*"
        },
        {
            "Sid": "DeployLaunchTemplate",
            "Effect": "Allow",
            "Action": [
                "ec2:CreateLaunchTemplateVersion",
                "ec2:ModifyLaunchTemplate"
            ],
            "Resource": "arn:aws:ec2:ap-northeast-2:ACCOUNT_ID:launch-template/*"
        },
        {
            "Sid": "DeployAsg",
            "Effect": "Allow",
            "Action": [
                "autoscaling:StartInstanceRefresh",
                "autoscaling:UpdateAutoScalingGroup"
            ],
            "Resource": "arn:aws:autoscaling:ap-northeast-2:ACCOUNT_ID:autoScalingGroup:*:autoScalingGroupName/siglens-asg"
        },
        {
            "Sid": "PassEc2Role",
            "Effect": "Allow",
            "Action": ["iam:PassRole"],
            "Resource": "arn:aws:iam::ACCOUNT_ID:role/siglens-ec2-role"
        },
        {
            "Sid": "AmiParam",
            "Effect": "Allow",
            "Action": ["ssm:GetParameter", "ssm:GetParameters"],
            "Resource": "arn:aws:ssm:ap-northeast-2::parameter/aws/service/*"
        },
        {
            "Sid": "BuildTimeDbUrl",
            "Effect": "Allow",
            "Action": ["ssm:GetParameter"],
            "Resource": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/siglens/DATABASE_URL"
        },
        {
            "Sid": "EnvCompletenessCheck",
            "Effect": "Allow",
            "Action": ["ssm:GetParametersByPath"],
            "Resource": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/siglens/*"
        },
        {
            "Sid": "IsrCachePurge",
            "Effect": "Allow",
            "Action": ["s3:ListBucket", "s3:DeleteObject"],
            "Resource": [
                "arn:aws:s3:::siglens-isr-cache",
                "arn:aws:s3:::siglens-isr-cache/*"
            ]
        },
        {
            "Sid": "IsrBuildIdParam",
            "Effect": "Allow",
            "Action": ["ssm:GetParameter", "ssm:PutParameter"],
            "Resource": "arn:aws:ssm:ap-northeast-2:ACCOUNT_ID:parameter/siglens/prev-isr-buildid"
        },
        {
            "Sid": "BuildTimeDbUrlDecrypt",
            "Effect": "Allow",
            "Action": ["kms:Decrypt"],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "kms:ViaService": "ssm.ap-northeast-2.amazonaws.com"
                }
            }
        }
    ]
}
